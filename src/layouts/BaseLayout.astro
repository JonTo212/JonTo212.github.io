---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from "../components/layout/NavBar.astro";

interface Props {
  title?: string;
}

const { title = "Jonathan To" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Header />

    <!-- BREADCRUMB — pages can override via slot -->
    <slot name="breadcrumb" />

    <!-- PAGE GRID -->
    <div class="page">
      <slot />
    </div>
  </body>
</html>
