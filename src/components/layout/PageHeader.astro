---
interface Props {
  comment: string;
  title: string;
  subtitle?: string;
  accentColor?: "green" | "yellow";
}

const { comment, title, subtitle, accentColor = "green" } = Astro.props;
const accentHex = accentColor === "green" ? "bg-[#7ec87e]" : "bg-[#c8b97e]";
const textHex = accentColor === "green" ? "text-[#7ec87e]" : "text-[#c8b97e]";
---

<header
  class="relative overflow-hidden border border-[#3a3a3a] bg-[#222222] px-10 pb-10 pt-12"
>
  <div class={`absolute inset-x-0 top-0 h-[2px] opacity-60 ${accentHex}`}></div>
  <span
    class="mb-6 block text-xs tracking-wider text-[#4a7a4a] leading-[1.9]"
    set:html={comment}
  />
  <h1
    class={`mb-2 text-5xl font-bold tracking-tight leading-[1.05] ${textHex}`}
  >
    {title}
  </h1>
  {
    subtitle && (
      <p class="mt-1.5 text-[13px] text-[#888888] leading-[1.85] before:content-['//_'] before:text-[#4a7a4a]">
        {subtitle}
      </p>
    )
  }
</header>
