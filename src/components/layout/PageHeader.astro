---
interface Props {
  comment: string;
  title: string;
  subtitle?: string;
  accentColor?: "green" | "yellow";
  subtitleColor?: "green" | "yellow";
}

const {
  comment,
  title,
  subtitle,
  accentColor = "green",
  subtitleColor,
} = Astro.props;
const accentHex = accentColor === "green" ? "bg-[#7ec87e]" : "bg-[#c8b97e]";
const titleHex = accentColor === "green" ? "text-[#7ec87e]" : "text-[#c8b97e]";
const subHex = subtitleColor
  ? subtitleColor === "green"
    ? "text-[#7ec87e]"
    : "text-[#c8b97e]"
  : titleHex;
---

<header
  class="relative overflow-hidden border border-[#3a3a3a] bg-[#222222] px-10 pb-10 pt-12"
>
  <div class={`absolute inset-x-0 top-0 h-[2px] opacity-60 ${accentHex}`}></div>
  <span
    class="mb-6 block text-[0.9rem] tracking-wider text-[#4a7a4a] leading-[1.9]"
    set:html={comment}
  />
  <h1
    class={`mb-2 text-5xl font-bold tracking-tight leading-[1.05] ${titleHex}`}
  >
    {title}
  </h1>
  {
    subtitle && (
      <p
        class={`mt-3 text-[0.9rem] leading-[1.8] before:content-['//_'] before:text-[#4a7a4a] ${subHex}`}
      >
        {subtitle}
      </p>
    )
  }
  <slot />
</header>
