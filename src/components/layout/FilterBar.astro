---
interface Props {
  filters: string[];
  accentColor?: "green" | "yellow";
}
const { filters, accentColor = "green" } = Astro.props;
---

<div class="flex flex-wrap items-center gap-2.5">
  <span class="mr-1 text-[0.9rem] text-[#555555]">// filter:</span>
  {
    filters.map((filter, index) => (
      <button
        class={`filter-btn font-mono text-[0.9rem] px-4 py-1.5 border border-[#3a3a3a] bg-[#222222] text-[#888888] rounded-[3px] transition-all duration-150 hover:border-[${accentColor === "green" ? "#7ec87e" : "#c8b97e"}] hover:text-[${accentColor === "green" ? "#7ec87e" : "#c8b97e"}] hover:bg-[#2a2515] ${index === 0 ? "active border-[#c8b97e] text-[#c8b97e] bg-[#2a2515]" : ""}`}
        data-accent={accentColor}
      >
        {filter}
      </button>
    ))
  }
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");
    const countDisplay = document.querySelector(".count");

    if (!btns.length || !cards.length) return;

    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        // Reset styles based on accent
        btns.forEach((b) => {
          b.classList.remove("active");
          b.style.borderColor = "#3a3a3a";
          b.style.color = "#888888";
          b.style.backgroundColor = "#222222";
        });

        btn.classList.add("active");
        const accent = btn.dataset.accent === "green" ? "#7ec87e" : "#c8b97e";
        const bgAccent = btn.dataset.accent === "green" ? "#1e2b1e" : "#2a2515";

        btn.style.borderColor = accent;
        btn.style.color = accent;
        btn.style.backgroundColor = bgAccent;

        const filter = btn.textContent?.trim().toLowerCase() || "";

        cards.forEach((card) => {
          if (filter === "all") {
            card.style.display = "flex";
          } else {
            const tags = Array.from(card.querySelectorAll(".tag")).map(
              (t) => t.textContent?.toLowerCase() || "",
            );
            card.style.display = tags.some((t) => t.includes(filter))
              ? "flex"
              : "none";
          }
        });

        if (countDisplay) {
          const visible = Array.from(cards).filter(
            (c) => c.style.display !== "none",
          ).length;
          countDisplay.textContent = `// ${visible} entries`;
        }
      });
    });
  });
</script>
