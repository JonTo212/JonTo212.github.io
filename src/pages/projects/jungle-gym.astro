---
// src/pages/portfolio/Jungle Gym/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoEmbed from "../../components/layout/VideoEmbed.astro";
import TextBlock from "../../components/layout/TextBlock.astro";
import ProjectDetails from "../../components/layout/ProjectDetails.astro";
import ProjectHeader from "../../components/layout/ProjectHeader.astro";
import KeyFeature from "../../components/layout/KeyFeature.astro";
import DeepDiveBlock from "../../components/layout/DeepDiveBlock.astro";
import ProjectFooter from "../../components/layout/ProjectFooter.astro";

const todoSnippetPlain = `// TODO: Add raw code snippet here`;
const todoSnippetHtml = ``;
---

<BaseLayout title="Jungle Gym - Jonathan To">
  <div slot="breadcrumb" class="breadcrumb-bar">
    <a href="/portfolio/">Portfolio()</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Jungle_Gym</span>
  </div>

  <ProjectHeader
    title="Jungle Gym"
    subtitle="Programmer · Designer · 2nd Year Design Practice"
    tags={[
      { label: "Programming", type: "programming" },
      { label: "Design", type: "design" },
      { label: "Unity", type: "unity" },
    ]}
    description="A whimsical 3D platformer where you play as a monkey inspecting jungle gym attractions for safety. My first team project - I designed and programmed the player controller, the marble roll and hover mechanics, and an in-world rope feature, while adapting mid-project when a team member departed."
  />

  <VideoEmbed
    videoId="ScnZMqkIZFU"
    caption="// fig_01 - Jungle Gym trailer · Jungle Gym"
    alt="Jungle Gym Trailer"
  />

  <div class="grid gap-6" style="grid-template-columns: 1fr 260px;">
    <TextBlock
      title="Overview"
      content="Jungle Gym is a whimsical 3D platformer built around the premise of a monkey inspector making sure jungle gym attractions are safe to play on. My first experience working in a team, and one where I had to adapt when a member left partway through - absorbing their scope and keeping the project on track. I owned the player controller end-to-end: design and implementation of the base movement, the marble roll mode, the hover mechanic, and the rope environmental feature."
    />

    <TextBlock
      title="Contributions"
      content={[
        "Built the player controller - parametric movement using apex time/height, time-to-max-speed, time-to-zero, and slope handling calculations",
        "Implemented the marble roll and hover mechanics",
        "Analyzed playtest telemetry in Excel to identify pain points in player movement and input behaviour",
        "Iterated the rope feature from 360° swing to single-plane based on telemetry findings",
      ]}
    />

    <div style="grid-column:2; grid-row:1/3;">
      <ProjectDetails
        meta={[
          { key: "status", value: "complete", highlight: true },
          { key: "year", value: "2023–2024" },
          { key: "duration", value: "4 months" },
          { key: "team_size", value: "4 (team)" },
          { key: "platform", value: "PC" },
          { key: "context", value: "Academic" },
        ]}
        links={[
          {
            label: "Play on itch.io",
            href: "https://braedenhammill.itch.io/jungle-gym",
            icon: "▷",
          },
          {
            label: "View on GitHub",
            href: "https://github.com/BraedenHammill/TeamUhhh-JungleGym",
            icon: "◇",
          },
        ]}
      />
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div style="border:1px solid var(--border); background:var(--bg-panel);">
      <div
        style="padding:10px 16px; background:var(--bg-card); border-bottom:1px solid var(--border); font-family:'Commit Mono',monospace; font-size:1.1rem; color:var(--green-dim);"
      >
        // Key Features
      </div>
    </div>

    <KeyFeature
      index={1}
      title="Player Movement"
      description="The movement system is built around giving players a mixture of control options. Default movement prioritizes snappy, natural response. The roll is meant to emulate the feeling of a marble: players accelerate with terrain and have momentum-driven speed buildup, reduced directional control, and a slippery, weighty feel that fits the whimsical tone. A reference to waterslides - the way momentum carries you through curves and the loss of fine control - drove the design direction. On top of that, the hover acts as a recovery buffer, reducing gravity while held to give players time to reorient after a misjudged jump, taking the edge off mistakes without removing the consequence."
      imageGridLayout="offset"
      imageGrid={[
        {
          src: "/images/jungle-gym/movement-01.png",
          caption: "design doc snippet",
        },
        {
          src: "/images/jungle-gym/movement-02.png",
          caption: "movement flow sketch",
        },
        {
          src: "/images/jungle-gym/movement-03.gif",
          caption: "wip - roll velocity projection",
        },
        {
          src: "/images/jungle-gym/movement-04.gif",
          caption: "final - terrain acceleration",
        },
      ]}
    />

    <KeyFeature
      index={2}
      title="Rope and Balloon Objects"
      description="Environmental objects that expand player interaction options. The original rope allowed full 360-degree movement, which seemed flexible in theory, but playtesting revealed a problem: players found the motion unpredictable and disconnected from how a rope should behave. Telemetry and survey feedback showed players were losing control in ways that felt unfair rather than skill-based. Constraining the swing to a single plane immediately improved readability and predictability, making the mechanic easier to learn and more satisfying to master."
      imageGridLayout="offset"
      imageGrid={[
        {
          src: "/images/jungle-gym/rope-01.gif",
          caption: "wip - original 360° prototype",
        },
        {
          src: "/images/jungle-gym/rope-02.png",
          caption: "telemetry analysis presentation snippet",
        },
        {
          src: "/images/jungle-gym/rope-03.gif",
          caption: "final - single-plane rope",
        },
        {
          src: "/images/jungle-gym/balloon-04.gif",
          caption: "final - 360° balloon",
        },
      ]}
      flip={true}
    />
  </div>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    <DeepDiveBlock
      title="Deep dive - building the player controller"
      steps={[
        {
          tag: "problem",
          icon: "◎",
          title: "Tweaking raw forces isn't the same as controlling feel",
          body: "Early iterations of the controller used direct force and velocity values - tweak a number, play, repeat. The problem is those values don't map cleanly to what you actually care about: how high does the player jump, how long does it take to reach full speed, how does the arc feel. Small changes had unpredictable effects, and there was no stable language to discuss movement feel with the team.",
        },
        {
          tag: "approach",
          icon: "◈",
          title: "Parametric derivation from designer-legible values",
          body: "The fix was rederiving the physics from parameters that have direct design meaning - apex height, apex time, time-to-max-speed and time-to-zero. Given apex height and apex time, you can solve for the initial jump velocity and the gravity required to produce that arc. Ground acceleration follows from time-to-max-speed and target velocity, while friction derives from time-to-zero. Slope handling uses surface normal projection to keep movement grounded through geometry. Every tuning knob now corresponds to something you can describe in plain terms.",
        },
        {
          tag: "result",
          icon: "▸",
          title: "Faster iteration, clearer communication",
          body: "Having these derivations in place made a concrete difference in how quickly the feel could be dialled in. When a playtester said a jump felt too floaty, that translated directly to a reduction in apex time - not a guess at which raw value to adjust. It also made the controller easier to extend: the marble roll and hover were built on top of the same parametric base without breaking the existing tuning.",
        },
      ]}
      slider={{
        label: "jungle_gym_controller_visual",
        beforeSrc: "",
        afterSrc: "",
      }}
    />

    <TextBlock
      title="Takeaways"
      content={[
        {
          heading: "Teams change the way you work",
          body: "Coordinating design decisions, aligning on scope, and communicating intent across people rather than just executing solo required a different way of thinking. First-team experience is its own learning curve, separate from any technical skill.",
        },
        {
          heading: "Scope shifts - adapt or stall",
          body: "When a team member left mid-project, the work didn't disappear with them. Absorbing their responsibilities without derailing the rest of the project meant making fast calls about what mattered and what could be cut. That kind of triage under pressure is hard to rehearse.",
        },
        {
          heading: "Playtest feedback beats your instincts",
          body: "The rope originally worked in 360 degrees - it made sense on paper. Playtesting showed it felt wrong; unconstrained swing didn't read as a rope to players. Constraining it to a single plane fixed the feel immediately. The lesson: your read of a mechanic in isolation rarely survives contact with a player.",
        },
      ]}
    />
  </div>

  <ProjectFooter
    prev={{ label: "Bunker Down Demo", href: "../bunker-down-demo/" }}
    author="Jonathan To · Gameplay Programmer & Game Designer"
    year={2026}
  />
</BaseLayout>
