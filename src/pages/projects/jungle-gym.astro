---
// src/pages/portfolio/Jungle Gym/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoEmbed from "../../components/layout/VideoEmbed.astro";
import TextBlock from "../../components/layout/TextBlock.astro";
import ProjectDetails from "../../components/layout/ProjectDetails.astro";
import ProjectHeader from "../../components/layout/ProjectHeader.astro";
import KeyFeature from "../../components/layout/KeyFeature.astro";
import DeepDiveBlock from "../../components/layout/DeepDiveBlock.astro";
import ProjectFooter from "../../components/layout/ProjectFooter.astro";

const todoSnippetPlain = `// TODO: Add raw code snippet here`;
const todoSnippetHtml = ``;
---

<BaseLayout title="Jungle Gym - Jonathan To">
  <div slot="breadcrumb" class="breadcrumb-bar">
    <a href="/portfolio/">Portfolio()</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Jungle Gym.cs</span>
  </div>

  <ProjectHeader
    title="Jungle Gym"
    subtitle="Programmer · Designer · 2nd Year Design Practice"
    tags={[
      { label: "C#", type: "programming" },
      { label: "Game Design", type: "design" },
      { label: "Unity", type: "unity" },
    ]}
    description="A whimsical 3D platformer where you play as a monkey inspecting jungle gym attractions for safety. My first team project - I designed and programmed the player controller, the marble roll and hover mechanics, and an in-world rope feature, while adapting mid-project when a team member departed."
  />

  <VideoEmbed
    videoId="TODO_VIDEO_ID"
    caption="// fig_01 - Jungle Gym trailer · Jungle Gym"
    alt="Jungle Gym Trailer"
  />

  <div class="grid gap-6" style="grid-template-columns: 1fr 260px;">
    <TextBlock
      title="Overview"
      content="Jungle Gym is a whimsical 3D platformer built around the premise of a monkey inspector making sure jungle gym attractions are safe to play on. My first experience working in a team, and one where I had to adapt when a member left partway through - absorbing their scope and keeping the project on track. I owned the player controller end-to-end: design and implementation of the base movement, the marble roll mode, the hover mechanic, and the rope environmental feature."
    />

    <TextBlock
      title="Contributions"
      content={[
        "Built the player controller - parametric movement using apex time/height, time-to-max-speed, and slope handling calculations",
        "Implemented the marble roll and hover mechanics",
        "Analyzed playtest telemetry in Excel to identify pain points in player movement and input behaviour",
        "Iterated the rope feature from 360° swing to single-plane based on telemetry findings",
      ]}
    />

    <div style="grid-column:2; grid-row:1/3;">
      <ProjectDetails
        meta={[
          { key: "status", value: "complete", highlight: true },
          { key: "year", value: "2023–2024" },
          { key: "duration", value: "4 months" },
          { key: "team_size", value: "4 (team)" },
          { key: "platform", value: "PC" },
          { key: "context", value: "Academic" },
        ]}
        links={[
          {
            label: "TODO: Play on itch.io",
            href: "#",
            icon: "▷",
          },
          {
            label: "TODO: View on GitHub",
            href: "#",
            icon: "◇",
          },
        ]}
      />
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div style="border:1px solid var(--border); background:var(--bg-panel);">
      <div
        style="padding:10px 16px; background:var(--bg-card); border-bottom:1px solid var(--border); font-family:'Commit Mono',monospace; font-size:1.1rem; color:var(--green-dim);"
      >
        // Key Features
      </div>
    </div>

    <KeyFeature
      index={1}
      title="Player Controller"
      description="Rigidbody-based character controller built around parametric movement tuning - jump arc defined by apex height and apex time, ground acceleration defined by time-to-max-speed, and slope handling via surface normal projection. My first time working with these derivations directly; having explicit control over the feel of the movement rather than tweaking raw forces made iteration significantly faster."
      snippetLabel="PlayerController.cs - jump arc derivation"
      snippetFilename="PlayerController.cs"
      snippetCode={todoSnippetPlain}
      flip={true}
    >
      <pre
        slot="snippet-code"
        style="margin:0; padding:1.25rem 1.5rem; overflow-x:auto; background:var(--bg); font-size:12px; line-height:1.8; white-space:pre-wrap; word-break:break-word;"><code class="font-mono text-(--text-code)" set:html={todoSnippetHtml} /></pre>
    </KeyFeature>

    <KeyFeature
      index={2}
      title="Marble Roll"
      description="A distinct movement mode that shifts the controller into terrain-following acceleration - the player rolls across surfaces with momentum-driven speed buildup and reduced directional control, giving it a slippery, weighty feel that fits the whimsical tone of the game. Surface normals are used to align the roll direction to the terrain, keeping movement grounded through slopes and curved geometry."
      snippetLabel="MarbleRoll.cs - terrain-following acceleration"
      snippetFilename="MarbleRoll.cs"
      snippetCode={`// TODO: plug in your snippet here`}
    />

    <KeyFeature
      index={3}
      title="Hover"
      description="A recovery tool designed to give players a buffer when they've misjudged a jump. While the input is held, gravity is reduced to produce a gentle float, buying time to reorient and land safely. Simple by design - its purpose is to take the edge off mistakes without removing the consequence of making them."
      snippetLabel="PlayerController.cs - apex hover"
      snippetFilename="PlayerController.cs"
      snippetCode={`// TODO: plug in your snippet here`}
      flip={true}
    />
  </div>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    <DeepDiveBlock
      title="Deep dive - designing whimsical movement"
      steps={[
        {
          tag: "problem",
          icon: "◎",
          title: "Every movement feel has already been done",
          body: "Platformer movement has a well-worn design space - tight and snappy, floaty and forgiving, weighty and deliberate. Finding something that felt distinct without being arbitrary, and that actually matched the tone of the game, was the core design challenge.",
        },
        {
          tag: "approach",
          icon: "◈",
          title: "Waterslides as a movement reference",
          body: "The breakthrough came from thinking about waterslides - the way momentum carries you through curves, the loss of fine control, the slippery inevitability of it. That became the design direction for the marble roll: not tight platformer movement, but something that rewards reading the terrain ahead rather than correcting in the moment.",
        },
        {
          tag: "result",
          icon: "▸",
          title: "A feel that's genuinely its own",
          body: "The marble roll landed as the most characterful part of the project - slippery, terrain-driven, and tonally on point for a game about a monkey in a jungle gym. It also validated using a non-standard reference for movement design: the answer wasn't in other platformers.",
        },
      ]}
      slider={{
        label: "jungle_gym_movement_visual",
        beforeSrc: "",
        afterSrc: "",
      }}
    />

    <TextBlock
      title="Takeaways"
      content={[
        {
          heading: "Teams change the way you work",
          body: "Coordinating design decisions, aligning on scope, and communicating intent across people rather than just executing solo required a different way of thinking. First-team experience is its own learning curve, separate from any technical skill.",
        },
        {
          heading: "Scope shifts - adapt or stall",
          body: "When a team member left mid-project, the work didn't disappear with them. Absorbing their responsibilities without derailing the rest of the project meant making fast calls about what mattered and what could be cut. That kind of triage under pressure is hard to rehearse.",
        },
        {
          heading: "Playtest feedback beats your instincts",
          body: "The rope originally worked in 360 degrees - it made sense on paper. Playtesting showed it felt wrong; unconstrained swing didn't read as a rope to players. Constraining it to a single plane fixed the feel immediately. The lesson: your read of a mechanic in isolation rarely survives contact with a player.",
        },
      ]}
    />
  </div>

  <ProjectFooter
    prev={{ label: "Cosmic Ranger V", href: "../cosmic-ranger-v/" }}
    next={{ label: "TODO: Next Project", href: "#" }}
    author="Jonathan To · Gameplay Programmer & Game Designer"
    year={2026}
  />
</BaseLayout>
