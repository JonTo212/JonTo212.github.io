    <span class="tok-param">wishdir</span>  = <span class="tok-param">transform</span>.<span class="tok-method">TransformDirection</span>(<span class="tok-param">wishdir</span>).<span class="tok-method">normalized</span>;
    <span class="tok-keyword">float</span> <span class="tok-param">wishspeed</span>         = <span class="tok-param">wishdir</span>.magnitude * <span class="tok-param">moveSpeed</span>;
    <span class="tok-keyword">float</span> <span class="tok-param">wishspeedOriginal</span> = <span class="tok-param">wishspeed</span>;
    <span class="tok-keyword">float</span> <span class="tok-param">accel</span>             = <span class="tok-param">airAcceleration</span>;

    <span class="tok-keyword">if</span> (<span class="tok-param">inputVector</span>.x != <span class="tok-num">0</span>)
    {
        <span class="tok-keyword">if</span> (<span class="tok-param">wishspeed</span> &gt; <span class="tok-param">sideStrafeSpeed</span>) <span class="tok-param">wishspeed</span> = <span class="tok-param">sideStrafeSpeed</span>;
        <span class="tok-param">accel</span> = <span class="tok-param">sideStrafeAcceleration</span>;
    }

    <span class="tok-keyword">float</span> <span class="tok-param">modifiedWishspeed</span> = <span class="tok-param">crouched</span> ? <span class="tok-param">wishspeed</span> / <span class="tok-num">3f</span> : <span class="tok-param">wishspeed</span>;
    <span class="tok-keyword">float</span> <span class="tok-param">modifiedAccel</span>     = <span class="tok-param">crouched</span> ? <span class="tok-param">accel</span>     / <span class="tok-num">3f</span> : <span class="tok-param">accel</span>;

    <span class="tok-keyword">if</span> (<span class="tok-param">airControl</span> &gt; <span class="tok-num">0</span>)
        <span class="tok-method">AirControl</span>(<span class="tok-param">wishdir</span>, <span class="tok-param">wishspeedOriginal</span>);

    <span class="tok-method">Accelerate</span>(<span class="tok-param">wishdir</span>, <span class="tok-param">modifiedWishspeed</span>, <span class="tok-param">modifiedAccel</span>);
}

<span class="tok-comment">// ── AirControl ────────────────────────────────────────────────────────────────</span>
<span class="tok-comment">// Steers velocity direction toward wishdir without adding speed.</span>
<span class="tok-comment">// Dot product measures forward alignment: perfect forward = 1, 90° = 0.</span>
<span class="tok-comment">// Squared so off-axis input yields proportionally less control (45° → 50%).</span>
<span class="tok-keyword">void</span> <span class="tok-method">AirControl</span>(<span class="tok-type">Vector3</span> <span class="tok-param">wishdir</span>, <span class="tok-keyword">float</span> <span class="tok-param">wishspeed</span>)
{
    <span class="tok-keyword">if</span> (<span class="tok-param">wishspeed</span> == <span class="tok-num">0</span> || <span class="tok-type">Mathf</span>.<span class="tok-method">Abs</span>(<span class="tok-param">inputVector</span>.z) == <span class="tok-num">0</span>) <span class="tok-keyword">return</span>;

