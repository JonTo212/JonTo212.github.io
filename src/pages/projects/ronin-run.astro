    <span class="tok-param">playerVelocity</span>.y = <span class="tok-num">0</span>;

    <span class="tok-keyword">float</span> <span class="tok-param">speed</span> = <span class="tok-param">playerVelocity</span>.magnitude;
    <span class="tok-param">playerVelocity</span>.<span class="tok-method">Normalize</span>();

    <span class="tok-keyword">float</span> <span class="tok-param">dot</span>                   = <span class="tok-type">Vector3</span>.<span class="tok-method">Dot</span>(<span class="tok-param">playerVelocity</span>, <span class="tok-param">wishdir</span>);
    <span class="tok-keyword">float</span> <span class="tok-param">airControlCoefficient</span>  = <span class="tok-num">32f</span> * <span class="tok-param">airControl</span> * <span class="tok-param">dot</span> * <span class="tok-param">dot</span> * Time.deltaTime;

