const airStrafeSnippetPlain = `// ── AirMove ──────────────────────────────────────────────────────────────────
// Builds wish-direction from raw input, then dispatches to AirControl + Accelerate.
// Side-strafe input gets a tighter speed cap + higher acceleration for sharp cornering.
void AirMove()
{
    // Cancel forward input when strafing diagonally
    if (inputVector.z >= 0 && inputVector.x != 0)
        wishdir = new Vector3(inputVector.x, 0, 0);

    wishdir  = transform.TransformDirection(wishdir).normalized;
    float wishspeed         = wishdir.magnitude * moveSpeed;
    float wishspeedOriginal = wishspeed;
    float accel             = airAcceleration;

    if (inputVector.x != 0)
    {
        if (wishspeed > sideStrafeSpeed) wishspeed = sideStrafeSpeed;
        accel = sideStrafeAcceleration;
    }

    float modifiedWishspeed = crouched ? wishspeed / 3f : wishspeed;
    float modifiedAccel     = crouched ? accel     / 3f : accel;

    if (airControl > 0)
        AirControl(wishdir, wishspeedOriginal);

    Accelerate(wishdir, modifiedWishspeed, modifiedAccel);
}

// ── AirControl ────────────────────────────────────────────────────────────────
// Steers velocity direction toward wishdir without adding speed.
// Dot product measures forward alignment: perfect forward = 1, 90° = 0.
// Squared so off-axis input yields proportionally less control (45° → 50%).
void AirControl(Vector3 wishdir, float wishspeed)
{
    if (wishspeed == 0 || Mathf.Abs(inputVector.z) == 0) return;

    float yVel = playerVelocity.y;
    playerVelocity.y = 0;

    float speed = playerVelocity.magnitude;
    playerVelocity.Normalize();

    float dot                   = Vector3.Dot(playerVelocity, wishdir);
    float airControlCoefficient = 32f * airControl * dot * dot * Time.deltaTime;

    if (dot > 0)
    {
        playerVelocity.x = playerVelocity.x * speed + wishdir.x * airControlCoefficient;
        playerVelocity.z = playerVelocity.z * speed + wishdir.z * airControlCoefficient;
        playerVelocity.Normalize();
    }

    playerVelocity.x *= speed;
    playerVelocity.z *= speed;
    playerVelocity.y  = yVel;
}

// ── Accelerate ────────────────────────────────────────────────────────────────
// Projects current velocity onto wishdir to find how much speed we still need.
// Only applies force if there's a deficit - prevents accelerating past wishspeed.
public void Accelerate(Vector3 wishdir, float wishspeed, float accel)
{
    float accelspeed   = accel * Time.deltaTime * moveSpeed;
    float desiredspeed = Vector3.Dot(playerVelocity, wishdir);
    float addspeed     = wishspeed - desiredspeed;

    if (addspeed <= 0) return;
    if (accelspeed > addspeed) accelspeed = addspeed;

    playerVelocity += accelspeed * wishdir;
}`;

// ─── Shuriken base + WallRunShuriken override ────────────────────────────────
const shurikenSnippetPlain = `// ── ShurikenBaseClass ────────────────────────────────────────────────────────
// Shared landing behaviour for every shuriken variant.
// Freezes physics, snaps to the predicted impact point, and orients to the surface.
protected virtual void AttachToSurface(Collision collision)
{
    hit = true;
    rb.velocity        = Vector3.zero;
    rb.angularVelocity = Vector3.zero;
    rb.isKinematic     = true;
    boxCol.enabled     = false;
    hitNormal          = collision.contacts[0].normal;

    // finalPos is passed from the aim indicator so landing lines up with the preview
    if (finalPos != Vector3.zero)
        transform.position = finalPos;

    // Attach perpendicular to the collision point (+45 offset to match the model)
    Quaternion contactRotation = Quaternion.LookRotation(-hitNormal);
    transform.rotation = contactRotation * Quaternion.Euler(90, 0, 45);
}

// ── WallRunShuriken ───────────────────────────────────────────────────────────
// On landing: calls base to embed the shuriken, then re-layers the hit surface
// and swaps its material - turning any wall into a wall-runnable surface.
// ResetWallRunObject() reverses both changes when the shuriken is picked up.
protected override void AttachToSurface(Collision collision)
{
    base.AttachToSurface(collision);

    if (currentShuriken != null && oneWallAtATime)
        currentShuriken.ResetWallRunObject();

    collidedObject = collision.gameObject;
    originalLayer  = collidedObject.layer;

    collidedObject.layer = LayerMask.NameToLayer("WallRun");

    var renderer     = collidedObject.GetComponent<Renderer>();
    originalMaterial = renderer.material;
    renderer.material = wallRunMaterial;

    if (oneWallAtATime)
    {
        currentShuriken = this;
        gameObject.SetActive(false);
    }
}

public void ResetWallRunObject()
{
    if (collidedObject == null) return;

    collidedObject.layer = originalLayer;
    collidedObject.GetComponent<Renderer>().material = originalMaterial;

    if (currentShuriken == this && oneWallAtATime)
        currentShuriken = null;
}`;

