        <span class="tok-param">playerVelocity</span>.z = <span class="tok-param">playerVelocity</span>.z * <span class="tok-param">speed</span> + <span class="tok-param">wishdir</span>.z * <span class="tok-param">airControlCoefficient</span>;
        <span class="tok-param">playerVelocity</span>.<span class="tok-method">Normalize</span>();
    }

    <span class="tok-param">playerVelocity</span>.x *= <span class="tok-param">speed</span>;
    <span class="tok-param">playerVelocity</span>.z *= <span class="tok-param">speed</span>;
    <span class="tok-param">playerVelocity</span>.y  = <span class="tok-param">yVel</span>;
}

<span class="tok-comment">// ── Accelerate ────────────────────────────────────────────────────────────────</span>
<span class="tok-comment">// Projects current velocity onto wishdir to find how much speed we still need.</span>
<span class="tok-comment">// Only applies force if there's a deficit - prevents accelerating past wishspeed.</span>
<span class="tok-keyword">public</span> <span class="tok-keyword">void</span> <span class="tok-method">Accelerate</span>(<span class="tok-type">Vector3</span> <span class="tok-param">wishdir</span>, <span class="tok-keyword">float</span> <span class="tok-param">wishspeed</span>, <span class="tok-keyword">float</span> <span class="tok-param">accel</span>)
