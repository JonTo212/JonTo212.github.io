const airStrafeSnippetHtml = `<span class="tok-comment">// ── AirMove ──────────────────────────────────────────────────────────────────</span>
<span class="tok-comment">// Builds wish-direction from raw input, then dispatches to AirControl + Accelerate.</span>
<span class="tok-comment">// Side-strafe input gets a tighter speed cap + higher acceleration for sharp cornering.</span>
<span class="tok-keyword">void</span> <span class="tok-method">AirMove</span>()
{
    <span class="tok-comment">// Cancel forward input when strafing diagonally</span>
    <span class="tok-keyword">if</span> (<span class="tok-param">inputVector</span>.z &gt;= <span class="tok-num">0</span> &amp;&amp; <span class="tok-param">inputVector</span>.x != <span class="tok-num">0</span>)
