    <span class="tok-param">originalLayer</span>  = <span class="tok-param">collidedObject</span>.layer;

    <span class="tok-param">collidedObject</span>.layer = <span class="tok-type">LayerMask</span>.<span class="tok-method">NameToLayer</span>(<span class="tok-string">"WallRun"</span>);

