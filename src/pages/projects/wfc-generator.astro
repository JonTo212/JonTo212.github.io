---
// src/pages/personal-projects/wfc-generator/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoEmbed from "../../components/layout/VideoEmbed.astro";
import TextBlock from "../../components/layout/TextBlock.astro";
import ProjectDetails from "../../components/layout/ProjectDetails.astro";
import ProjectHeader from "../../components/layout/ProjectHeader.astro";
import KeyFeature from "../../components/layout/KeyFeature.astro";
import DeepDiveBlock from "../../components/layout/DeepDiveBlock.astro";
import ProjectFooter from "../../components/layout/ProjectFooter.astro";

const todoSnippetPlain = `// TODO: Add raw code snippet here`;
const todoSnippetHtml = ``;
---

<BaseLayout title="WFC Generator - Jonathan To">
  <div slot="breadcrumb" class="breadcrumb-bar">
    <a href="/personal-projects/">PersonalProjects()</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">WFCGenerator.cs</span>
  </div>

  <ProjectHeader
    title="WFC Generator"
    subtitle="Procedural Generation · Pathfinding (BFS + DFS)"
    tags={[
      { label: "Programming", type: "programming" },
      { label: "Unity (C#)", type: "unity" },
    ]}
    description="A procedural 2D map generator using Wave Function Collapse, with optional pathfinding support."
  />

  <!-- No video for this project; hero image used instead -->
  <div
    style="border:1px solid var(--border); background:var(--bg-card); overflow:hidden;"
  >
    <img
      src="/images/wfc-hero.png"
      alt="2D map generator using WFC, BFS and DFS with randomization to create multiple paths"
      style="width:100%; display:block;"
    />
    <div
      style="font-family:'Commit Mono',monospace; font-size:11px; color:var(--text-muted); padding:8px 12px; border-top:1px solid var(--border); background:var(--bg-panel);"
    >
      // fig_01 - 2D map generator using WFC, BFS and DFS with randomization to
      create multiple paths
    </div>
  </div>

  <div class="grid gap-6" style="grid-template-columns: 1fr 260px;">
    <TextBlock
      title="Overview"
      content="A solo personal project exploring procedural generation and pathfinding. The generator uses
        Wave Function Collapse to produce valid, constraint-satisfying 2D tile maps, with an optional
        pathfinding layer - supporting both BFS and DFS - that can overlay single or multiple paths
        across the generated output."
    />

    <TextBlock
      title="Contributions"
      content={[
        "Wave Function Collapse system - tile architecture built on ScriptableObjects and enum-defined face rules, with weighted randomness for tile selection",
        "Flexible pathfinding layer - integrated BFS and DFS algorithms with added randomization to produce natural, varied paths",
        "Multi-path support - extended pathfinding to handle multiple overlapping paths across a single generated map, enabling more complex interconnected layouts",
      ]}
    />

    <div style="grid-column:2; grid-row:1/3;">
      <ProjectDetails
        meta={[
          { key: "status", value: "complete", highlight: true },
          { key: "year", value: "2024" },
          { key: "duration", value: "3 months" },
          { key: "team_size", value: "1 (solo)" },
          { key: "platform", value: "PC" },
          { key: "context", value: "Personal / Educational" },
        ]}
        links={[
          {
            label: "View on GitHub",
            href: "https://github.com/JonTo212/Wave-Function-Collapse-Generator",
            icon: "◇",
          },
        ]}
      />
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div style="border:1px solid var(--border); background:var(--bg-panel);">
      <div
        style="padding:10px 16px; background:var(--bg-card); border-bottom:1px solid var(--border); font-family:'Commit Mono',monospace; font-size:1.1rem; color:var(--green-dim);"
      >
        // Key Features
      </div>
    </div>

    <KeyFeature
      index={1}
      title="Wave Function Collapse"
      description="A constraint-based WFC system that builds maps by progressively reducing possibilities across a grid.
        Every cell starts with a full set of valid tiles; the generator collapses the lowest-entropy cell first,
        then propagates adjacency constraints through a queue until the entire grid resolves.
        Tile data and adjacency rules are defined via ScriptableObjects with directional face enums, keeping
        the system scalable and easy to extend. Tile selection supports weighted randomness, allowing
        certain tiles to appear more frequently while preserving procedural variety."
      snippetLabel="WFCGenerator.cs - Collapse & propagation"
      snippetFilename="WFCGenerator.cs"
      snippetCode={todoSnippetPlain}
      flip={true}
    >
      <pre
        slot="snippet-code"
        style="margin:0; padding:1.25rem 1.5rem; overflow-x:auto; background:var(--bg); font-size:12px; line-height:1.8; white-space:pre-wrap; word-break:break-word;"><code class="font-mono text-(--text-code)" set:html={todoSnippetHtml} /></pre>
    </KeyFeature>

    <KeyFeature
      index={2}
      title="Breadth-First Search"
      description="Grid-based BFS pathfinding that guarantees the shortest path in an unweighted space.
        Uses a FIFO queue to explore tiles level-by-level, ensuring all possible routes are checked
        in increasing distance from the start. Neighbours are sorted by squared magnitude distance
        to the target before queuing, so the closest direction is always explored first - producing
        the absolute shortest valid path."
      snippetLabel="BFSPathfinder.cs - Queue & neighbour sort"
      snippetFilename="BFSPathfinder.cs"
      snippetCode={`// TODO: plug in your snippet here`}
    />

    <KeyFeature
      index={3}
      title="Depth-First Search"
      description="DFS pathfinding with randomization, using a LIFO stack so the most recently discovered
        direction is always explored next - producing long, continuous paths before the algorithm branches.
        Neighbour order is randomized before each push, which varies the search direction each run
        and produces more organic-looking routes instead of predictable snaking patterns caused by
        fixed directional bias."
      snippetLabel="DFSPathfinder.cs - Randomized neighbour push"
      snippetFilename="DFSPathfinder.cs"
      snippetCode={`// TODO: plug in your snippet here`}
      flip={true}
    />
  </div>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    <DeepDiveBlock
      title="Deep dive - adding pathfinding with multiple path support"
      steps={[
        {
          tag: "problem",
          icon: "◎",
          title: "Path lists don't cleanly connect",
          body: "The end of one path and the start of the next were often more than 1 unit apart. The collapse function expects every neighbour to be exactly 1 unit away, so any larger gap left a tile with no valid solution - resulting in a broken, uncollapsable tile at the junction.",
        },
        {
          tag: "approach",
          icon: "◈",
          title: "Adding an additional validation layer",
          body: "Instead of collapsing path lists directly, I first build a dictionary of every grid point and its valid connections. IsFaceNeighbour validates that each tile is exactly 1 unit from its neighbours before it gets added. AddConnections then loops through all paths to populate the dictionary, using a HashSet per entry to avoid duplicate connections. Only then does the collapse run, using each tile's connection count to select the correct tile type.",
        },
        {
          tag: "result",
          icon: "▸",
          title: "Validated junction resolution",
          body: "Paths of any count can now be combined and collapsed without broken junctions. Each tile resolves based on its connection count - tiles with one connection become ends, two form straight segments, and three or more create junctions. Overlapping paths emerge naturally without any hardcoded rules.",
        },
      ]}
      slider={{
        label: "path_junction_fix",
        beforeSrc: "",
        afterSrc: "",
      }}
    />

    <TextBlock
      title="Takeaways"
      content={[
        {
          heading: "Deeper learning through integration",
          body: "Working with multiple algorithms together, rather than studying each in isolation, forced a deeper understanding of how each works - the modifications required for them to operate in tandem surfaced edge cases that studying them separately never would have.",
        },
        {
          heading: "The power of constraints",
          body: "Just like in game design, a small set of well-defined rules can produce a huge range of outcomes. Procedural generation takes that idea and runs with it - simple adjacency constraints scaling into a genuinely varied map generator.",
        },
        {
          heading: "A worthwhile investment",
          body: "There's a steep learning curve getting into algorithmic thinking, but the payoff is real. This project made clear that algorithms aren't single-purpose solutions - they have the potential to produce a wide variety of results depending on how they're applied.",
        },
      ]}
    />
  </div>

  <ProjectFooter
    prev={{ label: "TODO: Prev Project", href: "#" }}
    next={{ label: "TODO: Next Project", href: "#" }}
    author="Jonathan To · Gameplay Programmer & Game Designer"
    year={2026}
  />
</BaseLayout>
