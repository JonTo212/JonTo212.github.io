}`;

// ─── Feature 2: DFSWithRandomization ─────────────────────────────────────────
const dfsSnippetPlain = `private List<Vector3Int> DFSWithRandomization(Vector3Int start, Vector3Int end)
{
    // DFS uses a stack for LIFO checking — commits down one branch
    // before backtracking, producing long, winding paths
    Stack<Vector3Int>                open      = new Stack<Vector3Int>();
    Dictionary<Vector3Int, Vector3Int> cameFrom = new Dictionary<Vector3Int, Vector3Int>();

    open.Push(start);
    cameFrom[start] = start;

    while (open.Count > 0)
    {
        Vector3Int current = open.Pop();
        if (current == end) break;

        // Shuffle before pushing so each run takes a different route
        List<Vector3Int> neighbours = GetNeighboursTowards(current, end);
        neighbours = Shuffle(neighbours);

        foreach (var direction in neighbours)
        {
            Vector3Int newDir = current + direction;

            if (!IsInsideGrid(newDir) || newDir.y != 0 || cameFrom.ContainsKey(newDir))
                continue;

            open.Push(newDir);
            cameFrom[newDir] = current;
        }
    }

    if (!cameFrom.ContainsKey(end))
        return null;

    // Rebuild path backwards from end → start, then reverse
    List<Vector3Int> path    = new List<Vector3Int>();
    Vector3Int currentReverse = end;

    while (currentReverse != start)
    {
        path.Add(currentReverse);
        currentReverse = cameFrom[currentReverse];
    }

    path.Add(start);
    path.Reverse();
    return path;
}`;

