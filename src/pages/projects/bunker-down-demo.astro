---
// src/pages/portfolio/bunker-down-demo/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoEmbed from "../../components/layout/VideoEmbed.astro";
import TextBlock from "../../components/layout/TextBlock.astro";
import ProjectDetails from "../../components/layout/ProjectDetails.astro";
import ProjectHeader from "../../components/layout/ProjectHeader.astro";
import KeyFeature from "../../components/layout/KeyFeature.astro";
import DeepDiveBlock from "../../components/layout/DeepDiveBlock.astro";
import ProjectFooter from "../../components/layout/ProjectFooter.astro";

const todoSnippetPlain = `// TODO: Add raw code snippet here`;
const todoSnippetHtml = ``;
---

<BaseLayout title="Bunker Down! Demo - Jonathan To">
  <div slot="breadcrumb" class="breadcrumb-bar">
    <a href="/portfolio/">Portfolio()</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">BunkerDownDemo.cs</span>
  </div>

  <ProjectHeader
    title="Bunker Down! Demo"
    subtitle="Gameplay Programmer · Contract"
    tags={[
      { label: "Programming", type: "programming" },
      { label: "Unity", type: "unity" },
    ]}
    description="A virtual demo of the physical board game, Bunker Down!, created as a marketing tool
      for our client's Kickstarter campaign. Worked as programmer on the card and deck systems, game
      phase manager, animated UI board, and co-developed a suite of NPC opponents with distinct
      decision-making behaviours."
  />

  <VideoEmbed
    videoId="sWID9_jK4Co"
    caption="// fig_01 - Gameplay Demo · Bunker Down! Demo"
    alt="Bunker Down! Demo Gameplay"
  />

  <div class="grid gap-6" style="grid-template-columns: 1fr 260px;">
    <TextBlock
      title="Overview"
      content="Served as the primary systems programmer - responsible for the card and deck architecture,
        the phase-driven game manager, and the UI board that serves as the player's sole interaction layer.
        Co-developed four NPC opponents, each with distinct behavioural profiles built on top of shared
        game systems."
    />

    <TextBlock
      title="Contributions"
      content={[
        "Scriptable object-based card and deck system, including card data architecture and runtime deck management",
        "Game manager handling turn structure and phase sequencing across all game states",
        "Animated UI game board, with all player interaction routed through physical-style board buttons",
        "Co-developed four NPC opponents with distinct resource and card-play behaviours",
      ]}
    />

    <div style="grid-column:2; grid-row:1/3;">
      <ProjectDetails
        meta={[
          { key: "status", value: "complete", highlight: true },
          { key: "year", value: "2023" },
          { key: "duration", value: "4 months" },
          { key: "team_size", value: "2 (team)" },
          { key: "platform", value: "PC / WebGL" },
          { key: "context", value: "Contract" },
        ]}
        links={[
          {
            label: "Play on itch.io",
            href: "#",
            icon: "▷",
          },
          {
            label: "View on GitHub",
            href: "#",
            icon: "◇",
          },
          {
            label: "Kickstarter Campaign",
            href: "#",
            icon: "□",
          },
        ]}
      />
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div style="border:1px solid var(--border); background:var(--bg-panel);">
      <div
        style="padding:10px 16px; background:var(--bg-card); border-bottom:1px solid var(--border); font-family:'Commit Mono',monospace; font-size:1.1rem; color:var(--green-dim);"
      >
        // Key Features
      </div>
    </div>

    <KeyFeature
      index={1}
      title="Card & Deck System"
      description="Scriptable object-based card architecture with runtime deck management.
        Cards define their own data, allowing decks to be authored and modified
        without code changes - designed for extensibility across card types and game modes."
      snippetLabel="CardData.cs - Scriptable object card definition"
      snippetFilename="CardData.cs"
      snippetCode={todoSnippetPlain}
      flip={true}
    >
      <pre
        slot="snippet-code"
        style="margin:0; padding:1.25rem 1.5rem; overflow-x:auto; background:var(--bg); font-size:12px; line-height:1.8; white-space:pre-wrap; word-break:break-word;"><code class="font-mono text-(--text-code)" set:html={todoSnippetHtml} /></pre>
    </KeyFeature>

    <KeyFeature
      index={2}
      title="Game Phase Manager"
      description="Centralised game manager driving turn structure and phase sequencing.
        Coordinates state transitions across draw, play, and resolution phases,
        with hooks for NPC turns and win condition evaluation."
      snippetLabel="GameManager.cs - Phase sequencing"
      snippetFilename="GameManager.cs"
      snippetCode={`// TODO: plug in your snippet here`}
    />

    <KeyFeature
      index={3}
      title="Animated UI Game Board"
      description="All player interaction delivered through a single physical-style button board,
        emulating the tactile feel of a tabletop game. UI state and transitions driven
        entirely by tweens, with board layout reflecting current game phase."
      snippetLabel="UIBoard.cs - Tween-driven state transitions"
      snippetFilename="UIBoard.cs"
      snippetCode={`// TODO: plug in your snippet here`}
      flip={true}
    />
  </div>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    <DeepDiveBlock
      title="Deep dive - designing a framework without a complete ruleset"
      steps={[
        {
          tag: "problem",
          icon: "◎",
          title: "Building a system before we knew what it needed to contain",
          body: "We didn't have complete card content or finalised rules at the start of production. The client was still shaping the game's design while we were building - which meant a rigid, content-coupled architecture would have required constant rework as requirements shifted.",
        },
        {
          tag: "approach",
          icon: "◈",
          title: "Scriptable objects as a contract between design and code",
          body: "The solution was to build around Unity's ScriptableObject system: cards became data assets that defined their own properties and behaviour hooks, with dynamic functionality (such as onClick handlers) registered at runtime rather than hardcoded per card type. The game manager and deck system treated cards as opaque data containers - meaning new card types, effects, and rules could be introduced by authoring assets rather than modifying core systems. The aim was a framework loose enough to grow with the design, without sacrificing the structure needed to keep state consistent.",
        },
        {
          tag: "result",
          icon: "▸",
          title:
            "A system that absorbed scope changes without structural rewrites",
          body: "When card rules and content shifted mid-production - as they did several times - the changes were largely contained to asset configuration rather than code. The separation between data and logic held up under real production pressure. The main limitation was that sufficiently complex card interactions still required code-side handling; a more expressive data layer (something closer to a command pattern per effect) would have pushed more flexibility into the assets themselves.",
        },
      ]}
      slider={{
        label: "deep_dive_visual",
        beforeSrc: "",
        afterSrc: "",
      }}
    />

    <TextBlock
      title="Takeaways"
      content={[
        {
          heading: "Scope isn't yours to protect",
          body: "Working under a publisher means executing someone else's vision - design decisions, timelines, and priorities are handed down, not negotiated. Learning to do good work within those constraints, rather than against them, was the job.",
        },
        {
          heading: "Know when to say no",
          body: "The client kept expanding scope with no change in compensation. We wanted to deliver, and for a while that instinct overrode our better judgment. Eventually we had to draw a line - and respecting our own time turned out to be better for the working relationship, not worse.",
        },
        {
          heading: "Visibility is part of the work",
          body: "The hardest meetings were the ones where backend progress had nothing visual to show. Learning to clearly articulate what had been built - and why it mattered - was as important as building it. Trust with a non-technical producer doesn't maintain itself.",
        },
      ]}
    />
  </div>

  <ProjectFooter
    prev={{ label: "Cosmic Ranger V", href: "../cosmic-ranger-v/" }}
    next={{ label: "TODO: Next Project", href: "#" }}
    author="Jonathan To · Gameplay Programmer & Game Designer"
    year={2026}
  />
</BaseLayout>
