import ProjectFooter from "../../components/layout/ProjectFooter.astro";

const todoSnippetPlain = `// TODO: Add raw code snippet here`;
const todoSnippetHtml = ``;
---

<BaseLayout title="JellyFish - Jonathan To">
  <div slot="breadcrumb" class="breadcrumb-bar">
    <a href="/portfolio/">Portfolio()</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">JellyFish.cs</span>
  </div>

  <ProjectHeader
    title="JellyFish"
    subtitle="Network Programmer · Co-op"
    tags={[
      { label: "Programming", type: "programming" },
      { label: "Unity", type: "unity" },
    ]}
    description="An online party game built for Steam with a custom lobby system. Served as the network programmer, rapidly learning multiplayer foundations in under two months. Implemented gameplay systems, networking infrastructure, and Steam features such as lobby management, hosting, and code-based invites."
  />

  <VideoEmbed
    videoId="rCs9Q9dPeNc"
    caption="// fig_01 - Gameplay Trailer · JellyFish"
    alt="JellyFish Trailer"
  />

  <div class="grid gap-6" style="grid-template-columns: 1fr 260px;">
    <TextBlock
      title="Overview"
      content="Joined as the primary network programmer on a Steam party game already in development - picking up FishNet and the Steam SDK from scratch in under two months. Owned the full networking stack: replication architecture, Steam lobby integration, the player controller, and all networked world devices. Shipped to Steam."
    />

    <TextBlock
      title="Contributions"
      content={[
        "FishNet networking backend, including scene loading, server-authoritative replication, and Steam-based hosting",
        "Custom lobby system with Steam codes, display names, synchronized UI, and host map select",
        "Networked player controller with simulated forces, moving platform sync, and punch knockback",
        "Replicated world devices - elevators, bridges, and other dynamic interactables",
      ]}
    />

    <div style="grid-column:2; grid-row:1/3;">
      <ProjectDetails
        meta={[
          { key: "status", value: "complete", highlight: true },
          { key: "year", value: "2025" },
          { key: "duration", value: "1.5 months" },
          { key: "team_size", value: "4" },
          { key: "platform", value: "PC (Steam)" },
          { key: "context", value: "Co-op" },
        ]}
        links={[
          {
            label: "Play on Steam",
            href: "https://store.steampowered.com/app/3887710/JellyFish/",
            icon: "▷",
          },
          {
            label: "View on GitHub",
            href: "https://github.com/JonTo212/JellyFishNetworkingRebuild",
            icon: "◇",
          },
        ]}
      />
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div style="border:1px solid var(--border); background:var(--bg-panel);">
      <div
        style="padding:10px 16px; background:var(--bg-card); border-bottom:1px solid var(--border); font-family:'Commit Mono',monospace; font-size:1.1rem; color:var(--green-dim);"
      >
        // key_features[]
      </div>
    </div>

    <KeyFeature
      index={1}
      title="Steam Lobby System"
      description="Custom lobby built on the Steamworks API - players create or join sessions via a generated lobby code, with Steam display names pulled and shown automatically. Lobby UI stays synchronized across all clients, with map selection for the host. On confirm, the host initiates a Steam-based connection and triggers networked scene loading via FishNet to transition all clients into the game simultaneously."
      videoSrc="/videos/jellyfish-lobby-loading-demo.mp4"
      snippetLabel="TODO_Filename.cs - lobby system"
      snippetFilename="TODO_Filename.cs"
      snippetCode={todoSnippetPlain}
      flip={true}
    >
      <pre
        slot="snippet-code"
        style="margin:0; padding:1.25rem 1.5rem; overflow-x:auto; background:var(--bg); font-size:12px; line-height:1.8; white-space:pre-wrap; word-break:break-word;"><code class="font-mono text-(--text-code)" set:html={todoSnippetHtml} /></pre>
    </KeyFeature>

    <KeyFeature
      index={2}
      title="Player Controller"
      description="Server-authoritative CharacterController-based movement using accumulated simulated forces to mimic rigidbody behaviour for consistency and predictability across clients. State is replicated to all clients each tick. Includes moving platform synchronization to prevent drift, and a punch mechanic that applies directional knockback force to other networked players."
      videoSrc="/videos/jellyfish-player-controller-demo.mp4"
      snippetLabel="TODO_Filename.cs - player controller"
      snippetFilename="TODO_Filename.cs"
      snippetCode={`// TODO: plug in your snippet here`}
    />

    <KeyFeature
      index={3}
      title="Networked World Devices"
      description="Moving level elements - elevators, bridges, fans, and other interactables - run authoritatively on the server and replicate position and state to all clients. Designed as a reusable backend so level designers could place and configure devices without writing networking code."
      videoSrc="/videos/networked-devices-demo.mp4"
      snippetLabel="TODO_Filename.cs - networked devices"
      snippetFilename="TODO_Filename.cs"
      snippetCode={`// TODO: plug in your snippet here`}
      flip={true}
    />
  </div>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    <DeepDiveBlock
      title="Deep dive - replicating player forces"
      steps={[
        {
          tag: "problem",
          icon: "◎",
          title:
            "Rigidbody movement was unpredictable across clients - and got worse on moving platforms",
          body: "The initial player controller used Unity's Rigidbody. In a single-player context that's fine; in a networked one, physics simulation diverges between host and clients, producing jitter, tunnelling, and inconsistent interactions with dynamic world elements. Moving platforms were especially bad - players would slip off or teleport as the platform's physics state and the player's didn't agree.",
        },
        {
          tag: "approach",
          icon: "◈",
          title:
            "Scrapped the Rigidbody - switched to a CharacterController with manually accumulated forces",
          body: "I moved to a CharacterController and accumulated all forces explicitly each frame - gravity, jump impulse, knockback, platform delta - then resolved them through a single Move() call. The server owns this calculation authoritatively and replicates the resulting position and velocity to clients. No physics engine involved, no divergence to reconcile. Platform sync worked by sampling the platform's world-space delta each tick and folding it directly into the move.",
        },
        {
          tag: "result",
          icon: "▸",
          title:
            "Predictable movement, reliable platform sticking, and a clean replication model",
          body: "Movement became stable and consistent across all clients. Knockback and jump forces behaved the same regardless of frame timing. Players stuck to moving platforms without drifting. The explicit force accumulation model also made it easy to add new force types - punch knockback, fans, launch pads - without touching the replication layer.",
        },
      ]}
      slider={{
        label: "TODO_visual_label",
        beforeSrc: "",
        afterSrc: "",
      }}
    />

    <TextBlock
      title="Takeaways"
      content={[
        {
          heading: "Networking from zero",
          body: "I had no multiplayer experience coming in. No networking framework, no mental model for replication, nothing. Owning the full stack under a tight deadline forced a fast and thorough understanding of server-authoritative architecture. It's a domain I didn't know at all six weeks prior, and left feeling comfortable in.",
        },
        {
          heading: "Steam & server types",
          body: "Shipping on Steam taught me how hosting actually works in practice - how Steam relays connections, what lobby codes map to under the hood, and the real tradeoffs between listen servers and dedicated servers. There's a lot Steam gives you, and a lot it doesn't. Knowing the line matters when you're building the whole thing yourself.",
        },
        {
          heading: "Simulating forces beats borrowing physics",
          body: "Getting platform sync right - and debugging why a Rigidbody falls apart across clients - built a clear intuition for why so many multiplayer games don't use physics engines for player movement. Manually accumulating forces is more work upfront, but the determinism is worth it.",
        },
      ]}
    />
  </div>

  <ProjectFooter
    prev={{ label: "Cosmic Ranger V", href: "../cosmic-ranger-v/" }}
    next={{ label: "TODO: Next Project", href: "#" }}
    author="Jonathan To · Gameplay Programmer & Game Designer"
    year={2026}
  />
</BaseLayout>
