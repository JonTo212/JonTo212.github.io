---
// src/pages/about.astro
import BaseLayout from "../layouts/BaseLayout.astro";

const skills = [
  {
    icon: "{}",
    label: "Engines / Editors",
    rows: [
      { name: "Unity", level: 5 },
      { name: "Unreal Engine 5", level: 4 },
      { name: "Godot", level: 3 },
    ],
  },
  {
    icon: "</>",
    label: "Languages",
    rows: [
      { name: "C#", level: 5 },
      { name: "Blueprints", level: 4 },
      { name: "C++", level: 3 },
    ],
  },
  {
    icon: "#!",
    label: "Tools",
    rows: [
      { name: "Git / GitHub", level: 4 },
      { name: "Jira / Atlassian", level: 4 },
      { name: "Microsoft Suite", level: 4 },
    ],
  },
];

const links = [
  { icon: "◇", label: "GitHub", href: "https://github.com/JonTo212" },
  { icon: "▷", label: "itch.io", href: "https://jonathanto.itch.io/" },
  {
    icon: "◈",
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/jonathan-to398/",
  },
  {
    icon: "□",
    label: "Resume (PDF)",
    href: "https://drive.google.com/file/d/1Cta6i9EEs6AEyEd8_VQpO21_3bMZjivW/view?usp=sharing",
  },
];
---

<BaseLayout title="About - Jonathan To">
  <!-- BREADCRUMB -->

  <!-- ── ABOUT ME ── -->
  <section class="section-block">
    <div class="section-block-header">
      <div class="dot"></div>
      // AboutMe()
    </div>
    <div class="section-block-body">
      <div class="about-float">
        <div class="profile-img-wrap">
          <img
            src="/cover-images/profile.png"
            alt="Jonathan To"
            class="profile-image"
          />
          <div class="profile-caption">// profile.png</div>
        </div>

        <p>
          Hey, I'm Jonathan! I'm a technical designer and Sheridan College Game
          Design graduate. I love tinkering with new ideas and tackling all the
          logic and implementation challenges that I encounter along the way. I
          strive to push my technical and creative boundaries every day to
          ultimately create things that are satisfying to interact with.
        </p>
        <p>
          Games have been my safe space since I was a child. To this day, I
          remember the excitement I used to feel rushing home from school, ready
          to boot up my PC to grind Maplestory and Runescape. That passion stuck
          with me so deeply that after earning a degree in Kinesiology, I
          decided to pivot and pursue a career in Game Design!
        </p>
        <p>
          As I continue my journey in game development, my goal is to create
          experiences that offer the same thrill that first drew me to games.
          Whether it's through immersive worldbuilding, unique gameplay, or
          satisfying movement, I just want to make something that lets players
          escape into something special, even if just for a little while.
        </p>
      </div>
    </div>
  </section>

  <!-- ── SKILLS ── -->
  <section>
    <div class="section-label">
      <div class="dot"></div>
      // Skills[]
    </div>
    <div class="skills-grid">
      {
        skills.map((group) => (
          <div class="skill-card">
            <div class="skill-card-header">
              <span class="skill-icon">{group.icon}</span>
              {group.label}
            </div>
            <div class="skill-rows">
              {group.rows.map((row) => (
                <div class="skill-row">
                  <span class="skill-name">{row.name}</span>
                  <div class="skill-dots">
                    {Array.from({ length: 5 }, (_, i) => (
                      <div class={`skill-dot${i >= row.level ? " dim" : ""}`} />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <section>
    <div class="section-label">
      <div class="dot"></div>
      // contact[]
    </div>
    <div class="links-grid">
      {
        links.map((link) => (
          <a
            class="link-card"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="link-card-left">
              <span class="link-card-icon">{link.icon}</span>
              {link.label}
            </div>
            <span class="link-card-arrow">→</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="footer-line">
    <span>// Jonathan To · Gameplay Programmer & Game Designer</span>
    <span>© 2026</span>
  </footer>
</BaseLayout>

<style>
  /* ── SECTION BLOCK ── */
  .section-block {
    border: 1px solid var(--border);
    background: var(--bg-panel);
  }
  .section-block-header {
    background: var(--bg-card);
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
    color: var(--green-dim);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    opacity: 0.5;
    flex-shrink: 0;
  }
  .section-block-body {
    padding: 1.5rem;
  }

  /* ── ABOUT FLOAT LAYOUT ── */
  .about-float {
    overflow: hidden; /* clearfix */
  }
  .about-float p {
    font-size: 14px;
    color: var(--text);
    line-height: 1.9;
    margin-bottom: 1.1rem;
  }
  .about-float p:last-child {
    margin-bottom: 0;
  }

  /* ── PROFILE IMAGE ── */
  .profile-img-wrap {
    float: right;
    width: 37.5%;
    margin: 0 0 1.25rem 1.75rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    overflow: hidden;
  }
  .profile-img-wrap img {
    width: 100%;
    display: block;
    filter: saturate(0.9);
  }
  .profile-caption {
    padding: 6px 10px;
    border-top: 1px solid var(--border);
    font-size: 10px;
    color: var(--text-muted);
  }

  /* ── SECTION LABEL ── */
  .section-label {
    font-size: 12px;
    color: var(--green-dim);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 1rem;
  }

  /* ── SKILLS GRID ── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .skill-card {
    background: var(--bg-panel);
  }
  .skill-card-header {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--green);
  }
  .skill-icon {
    font-size: 14px;
    color: var(--green-dim);
    font-style: normal;
  }
  .skill-rows {
    padding: 8px 0;
  }
  .skill-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 16px;
    border-bottom: 1px solid var(--border);
  }
  .skill-row:last-child {
    border-bottom: none;
  }
  .skill-name {
    font-size: 12px;
    color: var(--text-dim);
  }
  .skill-dots {
    display: flex;
    gap: 4px;
  }
  .skill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    opacity: 0.9;
  }
  .skill-dot.dim {
    opacity: 0.2;
  }

  /* ── LINKS / CONTACT ── */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .link-card {
    background: var(--bg-panel);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--text-dim);
    font-size: 12px;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .link-card:hover {
    background: var(--bg-card);
    color: var(--green);
  }
  .link-card-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .link-card-icon {
    font-size: 13px;
    color: var(--green-dim);
  }
  .link-card-arrow {
    opacity: 0.3;
    transition: opacity 0.15s;
  }
  .link-card:hover .link-card-arrow {
    opacity: 1;
  }

  /* ── FOOTER ── */
  .footer-line {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    font-size: 11px;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .profile-img-wrap {
      float: none;
      width: 100%;
      max-width: 220px;
      margin: 0 0 1.25rem 0;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
